---
// src/pages/topics/[slug].astro
// This page auto-generates one page per topic (e.g. /topics/ccna, /topics/linux-basics)
// Astro reads getStaticPaths() to know which pages to create at build time

import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Banner from '../../components/Banner.astro';
import { topics } from '../../data/topics.js';

export function getStaticPaths() {
  return topics.map(topic => ({
    params: { slug: topic.slug },
    props: { topic }
  }));
}

const { topic } = Astro.props;
---

<BaseLayout title={`${topic.title} | LearnHub`} description={topic.description}>
  <Navbar />

  <!-- Same Banner component, topic color as background -->
  <Banner
    title={`${topic.icon} ${topic.title}`}
    subtitle={topic.description}
    color={topic.color}
    height="320px"
    overlay={0.2}
  />

  <main style="max-width: var(--max); margin: 3rem auto; padding: 0 1.5rem;">
    <div style="margin-bottom: 2rem;">
      <a href="/" style="color: var(--muted); font-size: 0.875rem;">Home</a>
      <span style="color: var(--border); margin: 0 0.5rem;">/</span>
      <span style="font-size: 0.875rem; font-weight: 500;">{topic.title}</span>
    </div>

    <h2 style="font-size: 1.4rem; font-weight: 600; margin-bottom: 0.5rem;">
      {topic.subtopics.length} Subtopics
    </h2>
    <p style="color: var(--muted); margin-bottom: 2rem; font-size: 0.9rem;">
      Click any subtopic to read the full notes
    </p>

    <div class="subtopic-grid">
      {topic.subtopics.map((sub, index) => (
        <a href={`/topics/${topic.slug}/${sub.slug}`} class="subtopic-card">
          <div class="subtopic-card__num" style={`color: ${topic.color}; border-color: ${topic.color}20;`}>
            {String(index + 1).padStart(2, '0')}
          </div>
          <div class="subtopic-card__body">
            <h3 class="subtopic-card__title">{sub.title}</h3>
            <p class="subtopic-card__desc">{sub.description}</p>
          </div>
          <span class="subtopic-card__arrow" style={`color: ${topic.color};`}>→</span>
        </a>
      ))}
    </div>
  </main>

  <footer style="background: var(--primary); color: rgba(255,255,255,0.6); text-align: center; padding: 2rem; margin-top: 4rem; font-size: 0.875rem;">
    <p>© {new Date().getFullYear()} LearnHub</p>
  </footer>
</BaseLayout>

<style>
  .subtopic-grid { display: flex; flex-direction: column; gap: 0.75rem; }
  .subtopic-card {
    display: flex; align-items: center; gap: 1.25rem;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 1.25rem 1.5rem;
    transition: all 0.2s;
  }
  .subtopic-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow);
    transform: translateX(3px);
  }
  .subtopic-card__num {
    font-family: var(--mono); font-size: 1.1rem; font-weight: 600;
    border: 1px solid; border-radius: 6px;
    padding: 0.3rem 0.6rem; flex-shrink: 0;
  }
  .subtopic-card__body { flex: 1; }
  .subtopic-card__title { font-size: 1rem; font-weight: 600; margin-bottom: 0.25rem; }
  .subtopic-card__desc { color: var(--muted); font-size: 0.85rem; }
  .subtopic-card__arrow { font-size: 1.25rem; flex-shrink: 0; transition: transform 0.2s; }
  .subtopic-card:hover .subtopic-card__arrow { transform: translateX(4px); }
</style>
